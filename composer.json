{
    "name": "vasildakov/duck",
    "description": "A PHP duck model demonstrating composition over inheritance.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Vasil Dakov",
            "email": "vasildakov@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.0",
        "php-coveralls/php-coveralls": "^2.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "CoI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CoI\\": "tests/"
        }
    },
    "scripts": {
        "composer:test": "vendor/bin/phpunit",
        "composer:cs": "vendor/bin/phpcs",
        "composer:cs-fix": "vendor/bin/phpcbf",
        "composer:phpstan": "vendor/bin/phpstan analyse"
    }
}
